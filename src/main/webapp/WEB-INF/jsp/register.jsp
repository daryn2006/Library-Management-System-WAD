<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ page import="kz.example.lms.util.I18n" %>
<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title><%= I18n.t(request, "register.title") %></title><link rel="stylesheet" href="<%= request.getContextPath() %>/style.css"></head>
<body><div class="page"><nav class="nav"><div class="brand"><span class="brand-icon" aria-hidden="true">&#128214;</span><span><%= I18n.t(request, "nav.brand") %></span></div><div class="nav-links"><a href="<%= request.getContextPath() %>/"><%= I18n.t(request, "nav.home") %></a><a href="<%= request.getContextPath() %>/login"><%= I18n.t(request, "nav.login") %></a><a href="<%= request.getContextPath() %>/register?lang=ru"><%= I18n.t(request, "lang.ru") %></a><a href="<%= request.getContextPath() %>/register?lang=kk"><%= I18n.t(request, "lang.kk") %></a></div></nav>
<main class="container"><section class="hero"><span class="eyebrow"><%= I18n.t(request, "register.newAccount") %></span><h1><%= I18n.t(request, "register.createProfile") %></h1><p class="lead"><%= I18n.t(request, "register.lead") %></p></section>
<section class="section"><div class="panel"><% if (request.getAttribute("error") != null) { %><div class="message"><%= request.getAttribute("error") %></div><% } %><form method="post" action="<%= request.getContextPath() %>/register"><div class="form-grid"><label><span><%= I18n.t(request, "members.fullName") %></span><input type="text" name="fullName" required></label><label><span><%= I18n.t(request, "common.email") %></span><input type="email" name="email" required></label><label><span><%= I18n.t(request, "common.password") %></span><input type="password" name="password" required></label></div><div class="actions" style="margin-top:16px;"><button class="button" type="submit"><%= I18n.t(request, "register.createAccount") %></button><a class="button secondary" href="<%= request.getContextPath() %>/login"><%= I18n.t(request, "register.toLogin") %></a></div></form><p class="message" style="margin-top:16px;">Role is assigned by the administrator after registration.</p></div></section>
</main><%@ include file="partials/footer.jspf" %></div></body></html>

