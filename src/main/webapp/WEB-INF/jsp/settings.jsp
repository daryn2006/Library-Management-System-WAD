<%@ page contentType="text/html; charset=UTF-8" pageEncoding="UTF-8" %>
<%@ page import="kz.example.lms.model.User" %>
<%@ page import="kz.example.lms.util.I18n" %>
<!doctype html><html lang="en"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title><%= I18n.t(request, "settings.title") %></title><link rel="stylesheet" href="<%= request.getContextPath() %>/style.css"></head>
<body><div class="page"><%@ include file="partials/header.jspf" %><main class="container"><section class="hero"><span class="eyebrow"><%= I18n.t(request, "settings.title") %></span><h1><%= I18n.t(request, "settings.profile") %></h1><p class="lead"><%= I18n.t(request, "settings.lead") %></p></section>
<section class="section"><div class="panel"><div class="form-grid"><label><span><%= I18n.t(request, "members.fullName") %></span><input type="text" value="<%= user != null ? user.getFullName() : "-" %>" readonly></label><label><span><%= I18n.t(request, "common.email") %></span><input type="text" value="<%= user != null ? user.getEmail() : "-" %>" readonly></label><label><span><%= I18n.t(request, "common.role") %></span><input type="text" value="<%= user != null ? user.getRole() : "-" %>" readonly></label></div><div class="actions" style="margin-top:16px;"><a class="button secondary" href="<%= request.getContextPath() %>/home"><%= I18n.t(request, "common.back") %></a></div></div></section>
</main><%@ include file="partials/footer.jspf" %></div></body></html>
